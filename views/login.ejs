<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1">
<title>Login — DU Tender Management</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  body{font-family:'Inter',sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#0F2027 0%,#203A43 50%,#2C5364 100%);}
  .login-card{background:#fff;border-radius:20px;box-shadow:0 25px 60px rgba(0,0,0,.35);width:100%;max-width:420px;padding:2.5rem;}
  .logo-box{width:56px;height:56px;border-radius:14px;background:linear-gradient(135deg,#1E40AF,#3B82F6);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1.3rem;margin:0 auto 1rem;}
  .btn-du{background:#1E40AF;color:#fff;font-weight:600;border-radius:10px;padding:.65rem;}
  .btn-du:hover{background:#1c3aa0;color:#fff;}
  .form-control{border-radius:10px;padding:.65rem .9rem;}
</style>
</head>
<body>
  <div class="login-card">
    <div class="logo-box">DU</div>
    <h4 class="text-center fw-bold mb-1" style="color:#1E293B">DU Tender Management</h4>
    <p class="text-center text-muted mb-4" style="font-size:.9rem">Dhofar University — Procurement Portal</p>
    <% if (error) { %><div class="alert alert-danger py-2" style="font-size:.88rem"><%= error %></div><% } %>
    <% if (msg) { %><div class="alert alert-success py-2" style="font-size:.88rem"><%= msg %></div><% } %>
    <form method="POST" action="/login">
      <div class="mb-3">
        <label class="form-label fw-semibold" style="font-size:.88rem">Email Address</label>
        <input type="email" name="email" class="form-control" placeholder="you@du.edu.om" required>
      </div>
      <div class="mb-4">
        <label class="form-label fw-semibold" style="font-size:.88rem">Password</label>
        <input type="password" name="password" class="form-control" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn btn-du w-100">Sign In</button>
    </form>
    <p class="text-center mt-4 mb-0" style="font-size:.88rem">New supplier? <a href="/vendor-register" class="fw-semibold" style="color:#1E40AF">Register as Vendor</a></p>
  </div>
</body>
</html>
